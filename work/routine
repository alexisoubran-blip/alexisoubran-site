<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Rutina diaria mente-cuerpo</title>
  <link href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&f[]=cabinet-grotesk@500,700&display=swap" rel="stylesheet">
  <style>
    :root{
      --text-xs:clamp(.75rem,.7rem + .25vw,.875rem);
      --text-sm:clamp(.875rem,.8rem + .35vw,1rem);
      --text-base:clamp(1rem,.95rem + .25vw,1.06rem);
      --text-lg:clamp(1.125rem,1rem + .75vw,1.45rem);
      --text-xl:clamp(1.6rem,1.2rem + 1.8vw,2.2rem);
      --space-1:.25rem;--space-2:.5rem;--space-3:.75rem;--space-4:1rem;--space-5:1.25rem;--space-6:1.5rem;--space-8:2rem;--space-10:2.5rem;
      --color-bg:#050611;--color-surface:rgba(15,18,37,.64);--color-surface-2:rgba(27,31,58,.72);--color-surface-3:rgba(44,49,86,.82);--color-border:rgba(171,199,255,.18);
      --color-text:#eef4ff;--color-text-muted:#c5cff3;--color-text-faint:#939cc3;--color-primary:#86b7ff;--color-primary-2:#dc87ff;--color-accent:#79f0ff;--color-success:#7dffca;--color-warning:#ffcb81;
      --radius-md:1rem;--radius-lg:1.35rem;--radius-xl:1.8rem;--radius-full:999px;
      --shadow-sm:0 10px 30px rgba(0,0,0,.25);--shadow-lg:0 24px 60px rgba(0,0,0,.42);
      --font-body:'Satoshi',Inter,sans-serif;--font-display:'Cabinet Grotesk',Inter,sans-serif;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth;background:var(--color-bg)}
    body{min-height:100dvh;font-family:var(--font-body);font-size:var(--text-base);color:var(--color-text);background:
      radial-gradient(circle at 20% 15%, rgba(120,185,255,.2), transparent 22%),
      radial-gradient(circle at 78% 18%, rgba(210,120,255,.22), transparent 26%),
      radial-gradient(circle at 50% 70%, rgba(74,255,234,.12), transparent 24%),
      linear-gradient(180deg, #060713 0%, #090b1c 32%, #050611 100%);
      line-height:1.45;-webkit-font-smoothing:antialiased}
    body::before{content:"";position:fixed;inset:0;pointer-events:none;background:linear-gradient(130deg, rgba(255,255,255,.07), transparent 25%, rgba(115,224,255,.07) 46%, transparent 60%, rgba(232,138,255,.07) 78%, transparent 100%);mix-blend-mode:screen;opacity:.75}
    button,input,textarea{font:inherit}
    button{cursor:pointer;border:none;background:none;color:inherit}
    .shell{max-width:430px;min-height:100dvh;margin:0 auto;padding:calc(env(safe-area-inset-top) + 14px) 14px calc(env(safe-area-inset-bottom) + 96px);position:relative}
    .glass{background:linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.05));backdrop-filter:blur(18px) saturate(145%);-webkit-backdrop-filter:blur(18px) saturate(145%);border:1px solid var(--color-border);box-shadow:var(--shadow-sm)}
    .top-card,.panel,.sheet{border-radius:var(--radius-xl);overflow:hidden;position:relative}
    .top-card{padding:var(--space-5);position:sticky;top:calc(env(safe-area-inset-top) + 8px);z-index:5}
    .top-card::after,.panel::after{content:"";position:absolute;inset:auto -10% -30% 30%;height:100px;background:linear-gradient(90deg, transparent, rgba(127,223,255,.2), rgba(240,150,255,.16), transparent);transform:rotate(-12deg);filter:blur(12px);pointer-events:none}
    .eyebrow{font-size:var(--text-xs);text-transform:uppercase;letter-spacing:.16em;color:var(--color-text-faint)}
    h1{font-family:var(--font-display);font-size:var(--text-xl);line-height:1.02;letter-spacing:-.03em;margin-top:var(--space-2);max-width:11ch}
    .sub{margin-top:var(--space-3);color:var(--color-text-muted);font-size:var(--text-sm);max-width:32ch}
    .hero-row{display:flex;justify-content:space-between;align-items:flex-start;gap:var(--space-3)}
    .crystal-mark{width:54px;height:54px;flex:0 0 54px;border-radius:18px;position:relative;background:linear-gradient(145deg, rgba(160,229,255,.35), rgba(147,122,255,.12) 35%, rgba(255,130,233,.2) 68%, rgba(120,255,245,.14));border:1px solid rgba(255,255,255,.18);box-shadow:inset 0 1px 0 rgba(255,255,255,.15),0 8px 24px rgba(85,129,255,.24)}
    .crystal-mark::before{content:"";position:absolute;inset:8px;background:linear-gradient(160deg, rgba(255,255,255,.42), transparent 32%, rgba(126,204,255,.3) 54%, rgba(255,162,244,.26) 80%, transparent);clip-path:polygon(22% 0,100% 22%,74% 100%,0 78%);border-radius:10px}
    .hero-actions{display:flex;gap:10px;margin-top:var(--space-4)}
    .btn{min-height:46px;padding:.85rem 1rem;border-radius:999px;border:1px solid rgba(255,255,255,.12);background:rgba(255,255,255,.06);color:var(--color-text);font-size:var(--text-sm)}
    .btn.primary{background:linear-gradient(135deg, rgba(122,180,255,.34), rgba(229,127,255,.28));border-color:rgba(199,220,255,.24);box-shadow:0 10px 24px rgba(103,139,255,.25)}
    .btn.ghost{background:rgba(255,255,255,.03)}
    .btn.full{width:100%;justify-content:center}
    .stack{display:grid;gap:14px;margin-top:14px}
    .panel{padding:var(--space-5)}
    .section-title{font-size:var(--text-lg);font-weight:700;letter-spacing:-.02em}
    .muted{color:var(--color-text-muted)}
    .tiny{font-size:var(--text-xs);color:var(--color-text-faint)}
    .compact{display:grid;gap:12px}
    .progress-wrap{margin-top:var(--space-4)}
    .progress-bar{height:12px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden;border:1px solid rgba(255,255,255,.06)}
    .progress-bar span{display:block;height:100%;width:0;background:linear-gradient(90deg, #7fd4ff, #9f88ff 48%, #ff9ce8 100%);box-shadow:0 0 24px rgba(161,188,255,.55);transition:width .28s ease}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-top:var(--space-4)}
    .stat{padding:12px;border-radius:18px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08)}
    .stat .k{font-size:11px;color:var(--color-text-faint);text-transform:uppercase;letter-spacing:.12em}
    .stat .v{font-size:1.15rem;font-weight:700;margin-top:6px}
    .next-step{margin-top:var(--space-4);padding:14px;border-radius:20px;background:linear-gradient(135deg, rgba(134,183,255,.14), rgba(220,135,255,.12));border:1px solid rgba(191,214,255,.18)}
    .task-card{padding:16px;border-radius:24px;background:linear-gradient(135deg, rgba(124,186,255,.14), rgba(229,143,255,.1));border:1px solid rgba(173,204,255,.22);box-shadow:0 16px 40px rgba(77,101,188,.18)}
    .task-card h2{font-size:1.15rem;line-height:1.15}
    .task-card p{margin-top:8px;color:var(--color-text-muted)}
    .meta-row{display:flex;justify-content:space-between;align-items:center;gap:10px;margin-bottom:10px}
    .tag{font-size:11px;color:var(--color-text);padding:.34rem .58rem;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.09);white-space:nowrap}
    .helper{padding:12px 14px;border-radius:18px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08)}
    .filters,.chips,.actions-row{display:flex;flex-wrap:wrap;gap:8px;margin-top:12px}
    .filter,.chip,.mini-btn{padding:.58rem .84rem;border-radius:999px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);font-size:12px;color:var(--color-text-muted)}
    .filter.active{background:linear-gradient(135deg, rgba(125,183,255,.28), rgba(225,132,255,.22));color:var(--color-text);border-color:rgba(202,224,255,.18)}
    .timeline{display:grid;gap:12px}
    .block{padding:14px;border-radius:22px;background:rgba(255,255,255,.045);border:1px solid rgba(255,255,255,.08)}
    .block.current{background:linear-gradient(135deg, rgba(124,186,255,.14), rgba(229,143,255,.1));border-color:rgba(173,204,255,.22)}
    .block-top{display:flex;justify-content:space-between;gap:10px;align-items:flex-start}
    .block strong{font-size:1rem}
    .tasks{display:grid;gap:8px;margin-top:12px}
    .task{display:flex;gap:10px;align-items:flex-start;padding:6px 0}
    .task input{margin-top:3px;accent-color:#b9d3ff;width:18px;height:18px}
    .task span{color:var(--color-text-muted);font-size:var(--text-sm)}
    .task.done span{text-decoration:line-through;color:var(--color-text-faint)}
    .timer-face{padding:18px;border-radius:24px;background:radial-gradient(circle at 30% 20%, rgba(126,203,255,.18), transparent 25%), radial-gradient(circle at 75% 25%, rgba(236,121,255,.16), transparent 24%), rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);text-align:center}
    .timer-display{font-size:clamp(2.1rem,2rem + 2vw,3rem);font-weight:700;letter-spacing:-.04em;font-variant-numeric:tabular-nums}
    .timer-actions{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-top:12px}
    .bottom-nav{position:fixed;left:50%;transform:translateX(-50%);bottom:calc(env(safe-area-inset-bottom) + 10px);width:min(412px, calc(100vw - 20px));padding:8px;border-radius:24px;background:rgba(12,15,32,.72);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(190,210,255,.12);display:grid;grid-template-columns:repeat(3,1fr);gap:8px;box-shadow:var(--shadow-lg);z-index:30}
    .bottom-nav button{min-height:50px;border-radius:18px;font-size:12px;color:var(--color-text-muted);background:transparent}
    .bottom-nav button.active{background:linear-gradient(135deg, rgba(134,183,255,.18), rgba(220,135,255,.15));color:var(--color-text);border:1px solid rgba(196,220,255,.12)}
    .toast{position:fixed;left:50%;transform:translateX(-50%);bottom:calc(env(safe-area-inset-bottom) + 90px);padding:.85rem 1rem;border-radius:999px;background:rgba(11,13,28,.9);border:1px solid rgba(199,220,255,.14);color:var(--color-text);font-size:var(--text-sm);opacity:0;pointer-events:none;transition:all .2s ease;z-index:40;backdrop-filter:blur(12px)}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(-4px)}
    .sheet{position:fixed;inset:auto 14px calc(env(safe-area-inset-bottom) + 84px) 14px;padding:16px;z-index:35;display:none}
    .sheet.show{display:block}
    .sheet .actions-row{margin-top:14px}
    .hidden{display:none}
    @media (min-width:900px){
      .shell{max-width:920px;padding-inline:20px;padding-bottom:28px}
      .top-card{position:relative;top:auto}
      .stack.desktop{grid-template-columns:1.08fr .92fr;align-items:start}
      .bottom-nav{top:20px;right:20px;left:auto;transform:none;bottom:auto;width:260px}
      .sheet{left:auto;right:20px;bottom:20px;max-width:360px}
    }
  </style>
</head>
<body>
  <main class="shell">
    <section class="top-card glass">
      <div class="hero-row">
        <div>
          <div class="eyebrow">Rutina Flow</div>
          <h1>Haz más simple el siguiente paso.</h1>
          <p class="sub">Rediseñada para uso diario en celular: menos ruido, más claridad y progreso que sí se guarda.</p>
        </div>
        <div class="crystal-mark" aria-hidden="true"></div>
      </div>
      <div class="hero-actions">
        <button class="btn primary" id="focusModeBtn">Modo hoy</button>
        <button class="btn ghost" id="helpBtn">Ayuda</button>
      </div>
    </section>

    <section id="view-hoy" class="view stack desktop">
      <div class="stack">
        <article class="panel glass">
          <div class="section-title">Ahora mismo</div>
          <div class="task-card" id="focusCard" style="margin-top:14px"></div>
          <div class="actions-row">
            <button class="btn primary" id="completeNextBtn">Completar lo de arriba</button>
            <button class="btn ghost" id="nextActionBtn">Ir al bloque</button>
          </div>
          <div class="helper" style="margin-top:12px">
            <div class="tiny">Consejo</div>
            <div class="muted" id="helperText" style="margin-top:4px">Cuando dudes, vuelve a la acción mínima y no al sistema completo.</div>
          </div>
        </article>

        <article class="panel glass">
          <div class="section-title">Pulso del día</div>
          <div class="progress-wrap">
            <div class="progress-bar"><span id="progressBar"></span></div>
            <div class="stats">
              <div class="stat"><div class="k">Hechas</div><div class="v" id="doneCount">0</div></div>
              <div class="stat"><div class="k">Pendientes</div><div class="v" id="todoCount">0</div></div>
              <div class="stat"><div class="k">Bloques</div><div class="v" id="focusCount">0</div></div>
            </div>
          </div>
          <div class="chips">
            <span class="chip">El progreso se guarda solo</span>
            <span class="chip">Deshacer disponible</span>
          </div>
        </article>
      </div>

      <div class="stack">
        <article class="panel glass">
          <div class="meta-row">
            <div>
              <div class="section-title">Plan del día</div>
              <div class="tiny">Filtra para ver menos ruido</div>
            </div>
            <button class="mini-btn" id="expandBtn">Ver todo</button>
          </div>
          <div class="filters">
            <button class="filter active" data-filter="pending">Pendiente</button>
            <button class="filter" data-filter="all">Todo</button>
            <button class="filter" data-filter="done">Hecho</button>
          </div>
          <div class="timeline" id="timeline" style="margin-top:14px"></div>
        </article>

        <article class="panel glass">
          <div class="section-title">Entrar en foco</div>
          <div class="timer-face" style="margin-top:14px">
            <div class="tiny">Respira o prepárate</div>
            <div class="timer-display" id="timerDisplay">03:00</div>
            <div class="muted" style="margin-top:4px">Tres minutos antes de empezar.</div>
          </div>
          <div class="timer-actions">
            <button class="btn primary" id="timerStart">Iniciar</button>
            <button class="btn ghost" id="timerReset">Reiniciar</button>
            <button class="btn ghost" id="focusBtn">+1 bloque</button>
          </div>
        </article>
      </div>
    </section>

    <section id="view-ritmo" class="view hidden stack">
      <article class="panel glass">
        <div class="section-title">Ritmo diario</div>
        <div class="timeline" style="margin-top:14px">
          <div class="block"><div class="block-top"><div><strong>Mañana</strong><p class="muted">20–30 min</p></div><span class="tag">Encender</span></div><p class="muted" style="margin-top:10px">Agua, luz, movilidad y tres prioridades.</p></div>
          <div class="block"><div class="block-top"><div><strong>Deep work</strong><p class="muted">45–60 min</p></div><span class="tag">Enfocar</span></div><p class="muted" style="margin-top:10px">Respiración, objetivo exacto y notificaciones fuera.</p></div>
          <div class="block"><div class="block-top"><div><strong>Descarga</strong><p class="muted">5–10 min</p></div><span class="tag">Soltar</span></div><p class="muted" style="margin-top:10px">Camina, mira lejos y define el siguiente paso.</p></div>
          <div class="block"><div class="block-top"><div><strong>Cierre</strong><p class="muted">20 min</p></div><span class="tag">Cerrar</span></div><p class="muted" style="margin-top:10px">Escribe avances y estaciona una preocupación.</p></div>
        </div>
      </article>
    </section>

    <section id="view-mas" class="view hidden stack">
      <article class="panel glass">
        <div class="section-title">Más</div>
        <div class="timeline" style="margin-top:14px">
          <div class="block"><div class="block-top"><strong>Dispenza</strong><span class="tag">Inspiración</span></div><p class="muted" style="margin-top:10px">Observa el yo automático, entra en inducción breve y ensaya tu identidad futura sin confundir esto con tratamiento clínico.</p></div>
          <div class="block"><div class="block-top"><strong>Resetear progreso</strong><span class="tag">Acción</span></div><p class="muted" style="margin-top:10px">Usa esto solo al cerrar de verdad el día o empezar una jornada nueva.</p><div class="actions-row"><button class="btn ghost full" id="resetBtn">Reiniciar día</button></div></div>
          <div class="block"><div class="block-top"><strong>Ayuda rápida</strong><span class="tag">Uso</span></div><p class="muted" style="margin-top:10px">1) Entra a Hoy. 2) Haz la siguiente acción. 3) Marca completo. 4) Usa el timer antes del bloque.</p></div>
        </div>
      </article>
    </section>
  </main>

  <nav class="bottom-nav" aria-label="Navegación principal">
    <button class="active" data-view="hoy">Hoy</button>
    <button data-view="ritmo">Ritmo</button>
    <button data-view="mas">Más</button>
  </nav>

  <section class="sheet glass" id="helpSheet" aria-label="Ayuda rápida">
    <div class="section-title">Cómo usarla</div>
    <div class="timeline" style="margin-top:14px">
      <div class="block"><strong>1. Abre “Hoy”</strong><p class="muted" style="margin-top:8px">La app siempre te mostrará la siguiente acción más útil.</p></div>
      <div class="block"><strong>2. Completa una sola acción</strong><p class="muted" style="margin-top:8px">No necesitas revisar todo el sistema para avanzar.</p></div>
      <div class="block"><strong>3. Usa el timer</strong><p class="muted" style="margin-top:8px">Sirve para entrar a foco sin fricción.</p></div>
    </div>
    <div class="actions-row">
      <button class="btn primary full" id="closeHelpBtn">Entendido</button>
    </div>
  </section>

  <div class="toast" id="toast"></div>

  <script>
    const STORAGE_KEY = 'rutina-flow-state-v3';
    const routine = [
      {title:'Mañana · Activación', tag:'Encender', note:'20–30 min', tasks:['Tomar agua y buscar luz natural.','Hacer movilidad ligera de cuello, hombros y espalda.','Respirar 2–3 minutos con exhalación larga.','Escribir 3 prioridades y 1 cosa que no harás hoy.']},
      {title:'Antes del primer bloque', tag:'Enfocar', note:'10–15 min', tasks:['Respirar 4–4–8 durante 1–2 minutos.','Definir el objetivo exacto del bloque.','Quitar notificaciones y cerrar pestañas innecesarias.']},
      {title:'Después del bloque', tag:'Soltar', note:'5–10 min', tasks:['Levantarte y caminar 2–3 minutos.','Mirar a lo lejos para descargar vista y atención.','Anotar el siguiente paso antes de pasar a otra cosa.']},
      {title:'Tarde / noche', tag:'Recalibrar', note:'15–20 min', tasks:['Hacer caminata o ejercicio ligero.','Evitar meter tareas nuevas muy complejas tarde.','Separar el trabajo operativo del creativo.']},
      {title:'Cierre del día', tag:'Cerrar', note:'20 min', tasks:['Apagar redes y correos antes de dormir.','Escribir 3 avances del día.','Estacionar una preocupación con su primer paso para mañana.','Respirar, meditar o escuchar música calmada 5–10 minutos.']}
    ];

    let state = loadState();
    let timerInterval = null;
    let lastUndo = null;

    const timeline = document.getElementById('timeline');
    const doneCount = document.getElementById('doneCount');
    const todoCount = document.getElementById('todoCount');
    const focusCount = document.getElementById('focusCount');
    const progressBar = document.getElementById('progressBar');
    const focusCard = document.getElementById('focusCard');
    const toast = document.getElementById('toast');
    const timerDisplay = document.getElementById('timerDisplay');
    const helperText = document.getElementById('helperText');
    const helpSheet = document.getElementById('helpSheet');

    function defaultState(){
      return {completed:[], focusSessions:0, filter:'pending', timerSeconds:180, todayMode:true, expanded:false};
    }
    function loadState(){
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        return raw ? {...defaultState(), ...JSON.parse(raw)} : defaultState();
      } catch(e){
        return defaultState();
      }
    }
    function saveState(){
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch(e) {}
    }
    function completedSet(){ return new Set(state.completed); }
    function allTaskIds(){ return routine.flatMap((block, i) => block.tasks.map((_, idx) => `b${i}t${idx}`)); }

    function showToast(message, undo = false){
      toast.innerHTML = undo ? `${message} <button class="mini-btn" id="undoBtn" style="margin-left:8px">Deshacer</button>` : message;
      toast.classList.add('show');
      clearTimeout(showToast._t);
      if(undo){
        setTimeout(() => {
          const u = document.getElementById('undoBtn');
          if(u) u.onclick = undoLast;
        }, 0);
      }
      showToast._t = setTimeout(() => toast.classList.remove('show'), 2400);
    }

    function getNextPending(){
      const done = completedSet();
      for(let i=0;i<routine.length;i++){
        for(let idx=0; idx<routine[i].tasks.length; idx++){
          const id = `b${i}t${idx}`;
          if(!done.has(id)) return {id, blockIndex:i, taskIndex:idx, block:routine[i], task:routine[i].tasks[idx]};
        }
      }
      return null;
    }

    function renderFocusCard(){
      const next = getNextPending();
      if(!next){
        focusCard.innerHTML = `<div class="meta-row"><div class="tiny">Hoy está completo</div><span class="tag">Cierre</span></div><h2>Buen trabajo.</h2><p>Ya no hay tareas pendientes. Puedes cerrar el día o sumar otro bloque de foco.</p>`;
        helperText.textContent = 'Si terminaste todo, evita seguir “optimizando” la app y cierra el día.';
        return;
      }
      focusCard.innerHTML = `<div class="meta-row"><div class="tiny">Siguiente acción</div><span class="tag">${next.block.tag}</span></div><h2>${next.task}</h2><p>${next.block.title} · ${next.block.note}</p>`;
      helperText.textContent = `No abras otra sección hasta completar: “${next.task}”.`;
    }

    function renderTimeline(){
      timeline.innerHTML = '';
      const done = completedSet();
      const next = getNextPending();
      routine.forEach((block, i) => {
        const tasks = block.tasks.map((task, idx) => ({task, id:`b${i}t${idx}`, done:done.has(`b${i}t${idx}`)})).filter(item => {
          if(state.filter === 'pending') return !item.done;
          if(state.filter === 'done') return item.done;
          return true;
        });
        if(!state.expanded && state.filter === 'pending' && i > (next ? next.blockIndex : 0)) return;
        if(state.filter !== 'all' && tasks.length === 0) return;
        const wrap = document.createElement('article');
        wrap.className = 'block' + (next && next.blockIndex === i ? ' current' : '');
        wrap.innerHTML = `
          <div class="block-top">
            <div><strong>${block.title}</strong><p class="muted" style="margin-top:4px">${block.note}</p></div>
            <span class="tag">${block.tag}</span>
          </div>
          <div class="tasks">
            ${tasks.map(item => `<label class="task ${item.done?'done':''}"><input type="checkbox" data-id="${item.id}" ${item.done?'checked':''}><span>${item.task}</span></label>`).join('')}
          </div>`;
        timeline.appendChild(wrap);
      });
      if(!timeline.children.length){
        timeline.innerHTML = `<article class="block"><strong>Sin tareas en este filtro</strong><p class="muted" style="margin-top:10px">Prueba con “Todo” o vuelve a “Pendiente”.</p></article>`;
      }
      timeline.querySelectorAll('[data-id]').forEach(input => input.addEventListener('change', e => toggleTask(e.target.dataset.id, e.target.checked)));
      document.getElementById('expandBtn').textContent = state.expanded ? 'Ver menos' : 'Ver todo';
    }

    function toggleTask(id, isDone){
      const set = completedSet();
      lastUndo = {type:'task', id, previous:set.has(id)};
      if(isDone) set.add(id); else set.delete(id);
      state.completed = [...set];
      saveState();
      renderAll();
      showToast(isDone ? 'Tarea completada.' : 'Tarea reabierta.', true);
    }

    function undoLast(){
      if(!lastUndo) return;
      if(lastUndo.type === 'task'){
        const set = completedSet();
        if(lastUndo.previous) set.add(lastUndo.id); else set.delete(lastUndo.id);
        state.completed = [...set];
      } else if(lastUndo.type === 'reset'){
        state = {...state, ...lastUndo.snapshot};
      }
      saveState();
      renderAll();
      toast.classList.remove('show');
      lastUndo = null;
    }

    function updateProgress(){
      const total = allTaskIds().length;
      const done = state.completed.length;
      doneCount.textContent = done;
      todoCount.textContent = total - done;
      focusCount.textContent = state.focusSessions;
      progressBar.style.width = `${Math.round((done/total)*100)}%`;
    }

    function setView(view){
      document.querySelectorAll('[data-view]').forEach(btn => btn.classList.remove('active'));
      document.querySelectorAll(`button[data-view="${view}"]`).forEach(btn => btn.classList.add('active'));
      document.querySelectorAll('.view').forEach(v => v.classList.add('hidden'));
      document.getElementById(`view-${view}`).classList.remove('hidden');
    }

    function paintTimer(){
      const min = String(Math.floor(state.timerSeconds / 60)).padStart(2,'0');
      const sec = String(state.timerSeconds % 60).padStart(2,'0');
      timerDisplay.textContent = `${min}:${sec}`;
      document.getElementById('timerStart').textContent = timerInterval ? 'Pausar' : (state.timerSeconds < 180 && state.timerSeconds > 0 ? 'Continuar' : 'Iniciar');
    }

    function renderAll(){
      renderFocusCard();
      renderTimeline();
      updateProgress();
      paintTimer();
      saveState();
    }

    document.querySelectorAll('button[data-view]').forEach(btn => btn.addEventListener('click', () => setView(btn.dataset.view)));
    document.querySelectorAll('.filter').forEach(btn => btn.addEventListener('click', () => {
      state.filter = btn.dataset.filter;
      document.querySelectorAll('.filter').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      renderTimeline();
      saveState();
    }));

    document.getElementById('nextActionBtn').addEventListener('click', () => {
      const current = document.querySelector('.block.current') || document.querySelector('.block');
      if(current){ current.scrollIntoView({behavior:'smooth', block:'center'}); showToast('Te llevé al bloque actual.'); }
    });

    document.getElementById('completeNextBtn').addEventListener('click', () => {
      const next = getNextPending();
      if(next) toggleTask(next.id, true);
    });

    document.getElementById('expandBtn').addEventListener('click', () => {
      state.expanded = !state.expanded;
      renderTimeline();
      saveState();
    });

    document.getElementById('focusBtn').addEventListener('click', () => {
      state.focusSessions += 1;
      renderAll();
      showToast('Bloque registrado.');
    });

    document.getElementById('timerStart').addEventListener('click', () => {
      if(timerInterval){
        clearInterval(timerInterval); timerInterval = null; paintTimer(); showToast('Temporizador en pausa.'); return;
      }
      showToast(state.timerSeconds < 180 ? 'Temporizador reanudado.' : 'Temporizador iniciado.');
      timerInterval = setInterval(() => {
        state.timerSeconds -= 1; paintTimer(); saveState();
        if(state.timerSeconds <= 0){ clearInterval(timerInterval); timerInterval = null; state.timerSeconds = 0; paintTimer(); saveState(); showToast('Listo. Entra al bloque.'); }
      }, 1000);
      paintTimer();
    });

    document.getElementById('timerReset').addEventListener('click', () => {
      clearInterval(timerInterval); timerInterval = null; state.timerSeconds = 180; paintTimer(); saveState(); showToast('Temporizador reiniciado.');
    });

    document.getElementById('resetBtn').addEventListener('click', () => {
      if(!confirm('¿Reiniciar el día completo?')) return;
      lastUndo = {type:'reset', snapshot: JSON.parse(JSON.stringify(state))};
      state = {...defaultState(), filter:'pending'};
      clearInterval(timerInterval); timerInterval = null;
      document.querySelectorAll('.filter').forEach(b => b.classList.remove('active'));
      document.querySelector('.filter[data-filter="pending"]').classList.add('active');
      renderAll();
      showToast('Día reiniciado.', true);
    });

    document.getElementById('focusModeBtn').addEventListener('click', () => {
      setView('hoy');
      window.scrollTo({top:0,behavior:'smooth'});
      showToast('Volviste al modo hoy.');
    });

    document.getElementById('helpBtn').addEventListener('click', () => helpSheet.classList.add('show'));
    document.getElementById('closeHelpBtn').addEventListener('click', () => helpSheet.classList.remove('show'));
    document.addEventListener('keydown', (e) => { if(e.key === 'Escape') helpSheet.classList.remove('show'); });

    document.querySelectorAll('.filter').forEach(b => b.classList.remove('active'));
    document.querySelector(`.filter[data-filter="${state.filter}"]`)?.classList.add('active');

    setView('hoy');
    renderAll();
  </script>
</body>
</html>
